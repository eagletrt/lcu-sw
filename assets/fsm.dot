digraph "lcu_fsm" {
    bgcolor="white"
    layout="dot"
    center=true
    concentrate=false

    init [
        style="filled"
        color="#66ff66"
        fillcolor="#c1ffc1"
    ]
    flash
    idle
    fatal [
        style="filled"
        color="#ff6666"
        fillcolor="#ffc1c1"
    ]

    init -> idle [label="init_to_idle"]
    init -> fatal [label="init_to_fatal"]
    
    idle -> idle
    idle -> flash [label="idle_to_flash"]
    idle -> fatal [label="idle_to_fatal"]
    
    flash -> idle [label="flash_to_idle"]
    flash -> fatal [label="flash_to_fatal"]
    
    fatal -> flash
    fatal -> fatal
}
